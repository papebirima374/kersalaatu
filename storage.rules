rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// Règles Firebase Storage — Jappandal Tech (logos & photos produits)
//
// Déploiement : Console Firebase → Storage → onglet « Rules » → coller → Publier
// (ou  firebase deploy --only storage)
//
// Lecture publique (les images s'affichent sur les vitrines) ;
// écriture réservée aux comptes connectés, limitée aux images de moins de 5 Mo.
// ─────────────────────────────────────────────────────────────────────────

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
