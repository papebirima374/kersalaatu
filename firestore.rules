rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// Règles de sécurité Firestore — Jappandal Tech
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // E-mail du compte connecté, en minuscules ('' si absent).
    // NB : le langage des règles utilise lower(), pas toLowerCase().
    function userEmail() {
      return ('email' in request.auth.token) ? request.auth.token.email.lower() : '';
    }

    function isAdmin() {
      return signedIn() && userEmail() == 'papebirima374@gmail.com';
    }

    // Propriétaire d'une boutique : par uid OU par e-mail (certaines boutiques
    // anciennes n'ont pas d'ownerUid fiable — l'e-mail fait foi en secours).
    function ownsShopData(shop) {
      return signedIn() && (
        (('ownerUid' in shop) && shop.ownerUid == request.auth.uid)
        || (('ownerEmail' in shop) && shop.ownerEmail.lower() == userEmail())
      );
    }

    function isBoutiqueOwner(boutiqueId) {
      return ownsShopData(get(/databases/$(database)/documents/boutiques/$(boutiqueId)).data);
    }

    // Boutiques : vitrines publiques (lecture libre), écriture réservée au propriétaire connecté ou à l'admin
    match /boutiques/{id} {
      allow read: if true;
      allow create: if signedIn() && (ownsShopData(request.resource.data) || isAdmin());
      allow update, delete: if signedIn() && (ownsShopData(resource.data) || isAdmin());
    }

    // Produits : catalogues publics (lecture libre), écriture par le propriétaire de la boutique ou l'admin
    match /products/{id} {
      allow read: if true;
      allow create: if signedIn() && (isBoutiqueOwner(request.resource.data.boutiqueId) || isAdmin());
      allow update, delete: if signedIn() && (isBoutiqueOwner(resource.data.boutiqueId) || isAdmin());
    }

    // Commandes : un client peut créer sans compte ; lecture/gestion par le propriétaire ou l'admin
    match /orders/{id} {
      allow create: if true;
      // lecture/mise à jour par tout compte connecté : le MARCHAND (listener global)
      // et le CAISSIER (gestion des statuts) ; suppression réservée propriétaire/admin
      allow read, update: if signedIn();
      allow delete: if signedIn() && (isBoutiqueOwner(resource.data.boutiqueId) || isAdmin());
    }

    // Caissiers : comptes restreints créés par le marchand (id = uid Firebase Auth,
    // AUCUN mot de passe stocké). Lecture par compte connecté (détection du rôle
    // au login) ; création/suppression par le propriétaire de la boutique ou l'admin.
    match /caissiers/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && (isBoutiqueOwner(request.resource.data.boutiqueId) || isAdmin());
      allow delete: if signedIn() && (isBoutiqueOwner(resource.data.boutiqueId) || isAdmin());
      allow update: if false;
    }

    // Dépenses (Premium VIP) : gérées par le propriétaire de la boutique ou l'admin
    match /depenses/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && (isBoutiqueOwner(request.resource.data.boutiqueId) || isAdmin());
      allow update, delete: if signedIn() && (isBoutiqueOwner(resource.data.boutiqueId) || isAdmin());
    }

    // Tickets support : créés par le propriétaire, gérés/résolus par le propriétaire ou l'admin
    match /tickets/{id} {
      allow create: if signedIn() && request.resource.data.boutiqueId != null && isBoutiqueOwner(request.resource.data.boutiqueId);
      allow read: if signedIn();
      allow update, delete: if signedIn() && (isBoutiqueOwner(resource.data.boutiqueId) || isAdmin());
    }

    // Demandes de passage Pro/Premium : créées par le propriétaire, gérées/validées par l'admin
    match /upgradeRequests/{id} {
      allow create: if signedIn() && request.resource.data.boutiqueId != null && isBoutiqueOwner(request.resource.data.boutiqueId);
      allow read: if signedIn();
      allow update, delete: if isAdmin();
    }

    // Tout le reste : refusé
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
